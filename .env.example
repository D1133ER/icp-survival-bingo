# === Database ===
DATABASE_URL=postgresql://bingo:bingo_password@localhost:5432/bingo

# === Server ===
PORT=3000
NODE_ENV=development

# === Auth ===
# Generate a random secret: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=change-me-in-production-use-a-random-64-char-hex-string

# === CORS ===
# Comma-separated list of allowed origins (leave empty for same-origin only in production)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# === Rate Limiting ===
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100
